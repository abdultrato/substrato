    PatchedPacienteRequest:
      type: object
      description: |-
        Serializer para a entidade Paciente com validação robusta.
        Inclui campos de paciente para leitura/escrita com validação de domínio.
      properties:
        nome:
          type: string
          minLength: 2
          description: Nome completo do paciente (2-150 caracteres)
          maxLength: 150
        email:
          type: string
          format: email
          nullable: true
          title: E-mail
          description: Email único do paciente para contato
          maxLength: 254
        contacto:
          type: string
          nullable: true
          description: Número de telefone para contato (incluir indicativo país)
          maxLength: 9
        data_nascimento:
          type: string
          format: date
          nullable: true
          title: Data de nascimento
          description: Data de nascimento do paciente (formato YYYY-MM-DD)
        genero:
          allOf:
          - $ref: '#/components/schemas/GeneroEnum'
          default: Femenino
          title: Gênero
          description: |-
            Gênero do paciente (M ou F)

            * `Masculino` - Masculino
            * `Femenino` - Femenino
        raca_origem:
          allOf:
          - $ref: '#/components/schemas/RacaOrigemEnum'
          default: Negra
          title: Raça / Origem
          description: |-
            Classificação de raça/origem

            * `Branca` - Branca
            * `Negra` - Negra
            * `Parda` - Parda
            * `Amarela` - Amarela
            * `Indígena` - Indígena
            * `Outro` - Outro
        tipo_documento:
          allOf:
          - $ref: '#/components/schemas/TipoDocumentoEnum'
          default: BI
          title: Tipo de documento
          description: |-
            Tipo de documento de identidade (BI, CC, Passaporte, etc)

            * `BI` - Bilhete de Identidade
            * `PASS` - Passaporte
            * `DIRE` - Documento de Identificação de Residente Estrangeiro
            * `CC` - Carta de Condução
            * `NUIT` - Número Único de Identificação Tributária
            * `CE` - Cartão de Eleitor
            * `CN` - Certidão de Nascimento
            * `OUT` - Outro
        numero_id:
          type: string
          nullable: true
          title: Número do documento
          description: Número único do documento de identidade
          maxLength: 50
        morada:
          type: string
        proveniencia:
          default: Clínica Externa
          title: Proveniência
          description: |-
            Origem/proveniência do paciente na clínica

            * `Ambulatório` - Ambulatório
            * `Clínica Externa` - Clínica Externa
            * `Medicina Ocupacional` - Medicina Ocupacional
            * `Maternidade` - Maternidade
            * `Ginecologia` - Ginecologia
            * `Pediatria` - Pediatria
            * `Banco de Socorros` - Banco de Socorros
            * `Consulta Externa` - Consulta Externa
            * `Urologia` - Urologia
            * `Cirurgia` - Cirurgia
            * `Dentária` - Dentária
            * `Oftalmologia` - Oftalmologia
            * `Outro` - Outro
          oneOf:
          - $ref: '#/components/schemas/ProvenienciaEnum'
          - $ref: '#/components/schemas/BlankEnum'
        gestante:
          type: boolean
          default: false
          description: Indicador se paciente está gestante
        idade_gestacional_semanas:
          type: integer
          nullable: true
          title: Idade gestacional (semanas)
          description: Semanas de gestação (preencher apenas se gestante)
