{
  "name": "substrato-frontend",
  "version": "1.0.0",
  "description": "Substrato Healthcare Platform - Frontend",
  "private": true,
  "scripts": {
    "dev:clean-cache": "node -e \"require('fs').rmSync('.next-dev', { recursive: true, force: true })\"",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev -p 5000 -H 0.0.0.0",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "build:admin-css": "tailwindcss -c tailwind.admin.config.js -i styles/admin-tailwind.input.css -o ../apps/clinical/static/admin/css/substrato-admin-tailwind.css --minify",
    "start": "cross-env HOSTNAME=0.0.0.0 PORT=5000 node .next/standalone/server.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "node -e \"for (const dir of ['.next/types', '.next-dev/types']) require('fs').rmSync(dir, { recursive: true, force: true })\" && next typegen && tsc --noEmit --incremental false",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "generate:schema": "cd .. && node scripts/run-python.js generate_schema.py && node scripts/run-python.js scripts/convert_schema_json.py",
    "generate:api": "openapi-typescript-codegen --input http://localhost:8000/api/schema/ --output ./lib/api-client --useUnionTypes"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.18.1",
    "clsx": "^2.0.0",
    "lucide-react": "^0.263.0",
    "next": "^15.5.19",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.15.4",
    "typescript": "^5.0.0",
    "zod": "^4.4.3",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.5.19",
    "openapi-typescript-codegen": "^0.30.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "js-yaml": "^5.2.0",
    "minimatch": "^9.0.9",
    "postcss": "^8.5.16",
    "vite": "^8.1.0"
  }
}
