{
  "title": "Substrato – Backend",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Requests / s",
      "targets": [
        {
          "expr": "rate(django_http_requests_total_by_transport_total[1m])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Errors 5xx / m",
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 }
    },
    {
      "type": "stat",
      "title": "DB Connections",
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 }
    },
    {
      "type": "graph",
      "title": "Latency p95 (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_seconds_bucket[5m])) by (le)) * 1000",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "yaxes": [
        { "format": "ms", "logBase": 1 },
        { "format": "short", "logBase": 1 }
      ]
    },
    {
      "type": "graph",
      "title": "Requests by Status",
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total[5m])) by (status)",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 }
    },
    {
      "type": "graph",
      "title": "Celery Tasks Executed",
      "targets": [
        {
          "expr": "rate(celery_tasks_total[5m])",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 11 }
    },
    {
      "type": "graph",
      "title": "Celery Task Runtime p95 (s)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_runtime_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 11 }
    }
  ],
  "schemaVersion": 36,
  "version": 1,
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "time": { "from": "now-6h", "to": "now" }
}
