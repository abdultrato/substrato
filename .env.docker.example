DJANGO_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-only-change-before-shared-use
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
PROMETHEUS_BEARER_TOKEN=dev-metrics-token

DB_ENGINE=postgres
POSTGRES_DB=substrato
POSTGRES_USER=substrato
POSTGRES_PASSWORD=dev-postgres-password
DB_HOST=db
DB_PORT=5432

REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
JWT_SECRET=dev-only-change-before-shared-use

NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

TZ=Africa/Maputo
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

SUBSTRATO_OS_RUNTIME_ENABLED=false
SUBSTRATO_OS_RUNTIME_OFFLINE_ONLY=true
SUBSTRATO_OS_OUTBOX_PATH=/app/outbox
SUBSTRATO_OS_SYNC_BATCH_SIZE=50
SUBSTRATO_OS_SYNC_RETRY_AFTER_SECONDS=60

LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=3000
REDIS_HOST_PORT=6379
