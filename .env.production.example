DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-strong-secret-key
DJANGO_ALLOWED_HOSTS=api.example.com,app.example.com
FERNET_KEY=replace-with-fernet-key
DJANGO_TIME_ZONE=Africa/Maputo
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
PROMETHEUS_BEARER_TOKEN=replace-with-metrics-token

DB_ENGINE=postgres
DB_NAME=substrato
DB_USER=substrato
DB_PASSWORD=replace-with-database-password
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=require

USE_REDIS=true
REDIS_URL=redis://:replace-with-redis-password@redis:6379/0

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=notifications@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password

CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://app.example.com
LOG_LEVEL=INFO
LOG_FORMAT=json
SLACK_WEBHOOK=
