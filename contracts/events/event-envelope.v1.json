{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://substrato.local/contracts/events/event-envelope.v1.json",
  "title": "Substrato Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "tenant_id",
    "aggregate_id",
    "aggregate_version",
    "occurred_at",
    "trace_id",
    "idempotency_key",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "minLength": 3,
      "maxLength": 180
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "aggregate_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "aggregate_version": {
      "type": "integer",
      "minimum": 0
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140
    },
    "payload": {
      "type": "object"
    }
  }
}

