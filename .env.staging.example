DJANGO_ENV=staging
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-strong-secret-key
DJANGO_ALLOWED_HOSTS=staging-api.example.com,staging-app.example.com
FERNET_KEY=replace-with-fernet-key
DJANGO_TIME_ZONE=Africa/Maputo
PROMETHEUS_BEARER_TOKEN=replace-with-metrics-token

DB_ENGINE=postgres
DB_NAME=substrato_staging
DB_USER=substrato
DB_PASSWORD=replace-with-database-password
DB_HOST=db
DB_PORT=5432

REDIS_URL=redis://:replace-with-redis-password@redis:6379/0

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=notifications@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password

CORS_ALLOWED_ORIGINS=https://staging-app.example.com
CSRF_TRUSTED_ORIGINS=https://staging-app.example.com
LOG_LEVEL=INFO
LOG_FORMAT=json
MEDIA_STORAGE_LIMIT_BYTES=10737418240
